{
  "layers": {
    "worldcover": {
      "band_sets": [
        {
          "bands": [
            "B1"
          ],
          "dtype": "uint8"
        }
      ],
      "data_source": {
        "class_path": "rslearn.data_sources.worldcover.WorldCover",
        "init_args": {
          "metadata_cache_dir": "cache/worldcover"
        }
      },
      "resampling_method": "nearest",
      "type": "raster"
    }
  },
  "window_data_storage": {
    "class_path": "rslearn.dataset.window_data_storage.per_layer.PerLayerStorageFactory"
  }
}
