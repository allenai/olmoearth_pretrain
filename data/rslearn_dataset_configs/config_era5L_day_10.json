        "query_config": {
          "max_matches": 1,
          "space_mode": "SINGLE_COMPOSITE"
        },
        "time_offset": "-510d"
      },
      "type": "raster"
    }
  },
  "window_data_storage": {
    "class_path": "rslearn.dataset.window_data_storage.per_layer.PerLayerStorageFactory"
  }
}
